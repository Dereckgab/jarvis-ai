APP_ENV=development
APP_PORT=8080
APP_READ_TIMEOUT=30s
APP_WRITE_TIMEOUT=60s
APP_SHUTDOWN_TIMEOUT=15s

DATABASE_HOST=127.0.0.1
DATABASE_PORT=3307
DATABASE_USER=root
DATABASE_PASSWORD=password
DATABASE_NAME=jarvis_fullia

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=redispassword
REDIS_DB=0

SECURITY_JWT_SECRET=your_jwt_secret_here
SECURITY_JWT_EXPIRES_IN=168h
SECURITY_JWT_REFRESH_EXPIRES_IN=720h
SECURITY_CORS_ORIGINS=http://localhost:3000

AI_PROVIDER=groq
AI_GROQ_API_KEY=your_groq_api_key_here
AI_MODEL=llama-3.3-70b-versatile
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2048
